# =============================================================================
# NextRoulette — Variables d'environnement (EXEMPLE)
# -----------------------------------------------------------------------------
# Copier ce fichier en `.env.local` et remplir les valeurs.
# Ne JAMAIS committer de secret réel. Voir docs/SECURITY.md.
# =============================================================================

# URL publique de l'application (utilisée pour générer les liens d'invitation)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Authentification JWT
# -----------------------------------------------------------------------------
# Secret de signature des JWT. DOIT être long et aléatoire (>= 32 octets).
# Générer avec :  openssl rand -base64 48
JWT_SECRET="change-me-genere-un-secret-aleatoire-de-32-octets-minimum"

# Durées de validité des tokens
JWT_ACCESS_TTL="15m"   # token d'accès court
JWT_REFRESH_TTL="7d"   # token de rafraîchissement

# -----------------------------------------------------------------------------
# Compte admin de démonstration (fondation uniquement)
# -----------------------------------------------------------------------------
# Sera remplacé par une vraie table utilisateurs en base. Voir docs/ROADMAP.md.
ADMIN_EMAIL="admin@nextroulette.local"
# Hash bcrypt du mot de passe admin. Générer avec :
#   node -e "console.log(require('bcryptjs').hashSync('TON_MOT_DE_PASSE', 12))"
ADMIN_PASSWORD_HASH=""
